# Supabase — used by src/services/supabase.ts (https://supabase.com/dashboard)
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Trip share link (Edge Function `share-trip`), no trailing slash
# EXPO_PUBLIC_SHARE_TRIP_BASE_URL=https://<project-ref>.supabase.co/functions/v1/share-trip
EXPO_PUBLIC_SHARE_TRIP_BASE_URL=

# Public Mapbox token (client-safe). Create at https://account.mapbox.com/access-tokens/
EXPO_PUBLIC_MAPBOX_ACCESS_TOKEN=

# Optional: secret token with Downloads:Read for Android Gradle / SDK — see
# https://rnmapbox.github.io/docs/install?rebuild=expo
