{
  "expo": {
    "name": "DriftGuide",
    "slug": "DriftGuide",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "driftguide",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#0B1220"
    },
    "ios": {
      "bundleIdentifier": "com.driftguide.app",
      "buildNumber": "9",
      "supportsTablet": true,
      "usesAppleSignIn": true,
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.driftguide.app",
      "adaptiveIcon": {
        "backgroundColor": "#E8F4F8",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      "expo-apple-authentication",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow DriftGuide to access your photos for your profile picture.",
          "cameraPermission": "Allow DriftGuide to use the camera for your profile picture."
        }
      ],
      "@rnmapbox/maps"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "privacyPolicyUrl": "https://driftguide-web.vercel.app/privacy",
      "supportUrl": "https://driftguide-web.vercel.app/support",
      "router": {},
      "eas": {
        "projectId": "9a3383b1-f6c2-4153-bd28-0e4b1c5bb0de"
      }
    },
    "owner": "dfree22"
  }
}
